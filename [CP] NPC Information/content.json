{
 /*
 https://github.com/Pathoschild/StardewMods/blob/develop/ContentPatcher/docs/author-guide.md#create-the-content-pack
 Welcome to the content.json
 here is where you need these specific fields:
 Format
 Changes

 Optional things like ConfigSchema and DynamicTokens can be placed here
 let's go into the Format:
 */
 "Format": "2.9.0", //this is the current CONTENT PATCHER version as of June 3rd, 2026
 /*
 https://github.com/Pathoschild/StardewMods/blob/develop/ContentPatcher/docs/author-guide/config.md
 ConfigSchema is where you put things that can be seen either in a config.json that gets created upon a save load OR GMCM has its own menu for it
 They're all { Objects } with "Fields": ""

 */
 "ConfigSchema": {
  "TalkingHeads": {
   "AllowValues": "BigHeaded, SmallHeaded",
   "Default": "BigHeaded",
   "Section": "Appearance",
   "Description": "Talking Heads is currently in Super Alpha(TM) and I haven't done much except the first portrait. Default off."
  },
  "TalkingHeads2": {
   "AllowValues": "true, false",
   "Default": false,
   "Section": "Appearance",
   "Description": "Talking Heads is currently in Super Alpha(TM) and I haven't done much except the first portrait. Default off."
  }
 },
 "DyNamicTokens": [
  //misc tokens
  {
   "Name": "WeekDay",
   "When": {
    "DayOfWeek": "Monday"
   },
   "Value": "Mon"
  },
  {
   "Name": "WeekDay",
   "When": {
    "DayOfWeek": "Tuesday"
   },
   "Value": "Tue"
  },
  {
   "Name": "WeekDay",
   "When": {
    "DayOfWeek": "Wednesday"
   },
   "Value": "Wed"
  },
  {
   "Name": "WeekDay",
   "When": {
    "DayOfWeek": "Thursday"
   },
   "Value": "Thu"
  },
  {
   "Name": "WeekDay",
   "When": {
    "DayOfWeek": "Friday"
   },
   "Value": "Fri"
  },
  {
   "Name": "WeekDay",
   "When": {
    "DayOfWeek": "Saturday"
   },
   "Value": "Sat"
  },
  {
   "Name": "WeekDay",
   "When": {
    "DayOfWeek": "Sunday"
   },
   "Value": "Sun"
  }
 ],
 "Changes": [
  /*
  "CHANGES" is a <List> dictated by the [] (square brackets)
  This is where you put things like:
  "Action": "Load"
  "Action": "EditData",
  "Action": "Include",
  "Action": "EditMap",
  "Action": "EditImage"

  etc
  in this format, I will be writing everything in their own separate JSON files
  so I will be using all "INCLUDES" in the CONTENT.JSON

  you **CAN** load all of these things in one go, but i've separated them out so that smapi can yell at you if you just copy paste this in
  what it looks like:
  {
   "LogName": "INCLUDE ALL PATCHES",
   "Action": "Include",
   "FromFile": "LoadPatches.json, EditDataPatches.json, EditImagePatches.json, EditMapPatches.json, HighTierPlaysOnly.json"
  },
  */
  {
   "LogName": "INCLUDE LOAD PATCH",
   "Action": "Include",
   "FromFile": "ContentPatcher/LoadPatches.json"
  }
 ]
}
